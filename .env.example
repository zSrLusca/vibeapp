# Copie este arquivo para .env e preencha com seus valores.
# O arquivo .env NÃO deve ser commitado (está no .gitignore).

# E-mail(s) que recebem superadmin automaticamente ao cadastrar ou logar.
# Separe vários e-mails com vírgula.
VITE_SUPERADMIN_EMAIL=seuemail@gmail.com

